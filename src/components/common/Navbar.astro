---
import { navLinks } from "@/sitedata/navigation";
import { site } from "@/sitedata/site";
import Button from "@/components/ui/Button.astro";
---

<nav
    class="fixed top-0 w-full z-50 bg-surface/60 backdrop-blur-xl border-b border-on-surface/15 flex justify-between items-center px-6 md:px-12 py-6"
>
    <a
        href="/"
        class="text-2xl font-bold tracking-[-0.05em] text-on-surface font-headline uppercase hover:text-primary transition-colors"
    >
        {site.name}
    </a>

    <div class="hidden md:flex gap-12">
        {
            navLinks.map((link) => (
                <a
                    class="font-serif tracking-tighter uppercase font-light text-sm text-nav-links hover:text-primary transition-all duration-300 ease-[cubic-bezier(0.16,1,0.3,1)]"
                    href={link.href}
                >
                    {link.label}
                </a>
            ))
        }
    </div>

    <Button
        class="font-serif tracking-tighter uppercase font-light text-sm text-accent-violet hover:scale-x-105 transition-transform duration-500 border border-accent-violet/30 px-6 py-2"
    >
        INQUIRY
    </Button>
</nav>
