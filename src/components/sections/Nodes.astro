---
import Container from "@/components/common/Container.astro";
import { nodes } from "@/sitedata/sections";
---

<!-- Global Deployment -->
<section class="py-32 bg-surface">
    <Container>
        <div class="grid grid-cols-1 md:grid-cols-12 gap-12 items-center">
            <div class="md:col-span-4">
                <h2 class="font-headline text-5xl mb-8">
                    {nodes.title.main}<br />{nodes.title.accent}
                </h2>
                <p
                    class="font-body text-sm text-secondary leading-relaxed mb-12"
                >
                    {nodes.desc}
                </p>
                <div class="space-y-4">
                    {
                        nodes.items.map((node) => (
                            <div class="flex justify-between items-center py-4 border-b border-outline-variant/20">
                                <span class="font-label text-xs uppercase">
                                    {node.city}
                                </span>
                                <span class="font-label text-xs text-primary">
                                    {node.status}
                                </span>
                            </div>
                        ))
                    }
                </div>
            </div>
            <div
                class="md:col-span-8 aspect-video bg-surface-container-lowest relative overflow-hidden border border-outline-variant/10"
            >
                <!-- Imagen real usando worldmap.png -->
                <div class="absolute inset-0 opacity-20 pointer-events-none">
                    <img
                        src="/images/worldmap.png"
                        alt="Technical world map"
                        class="w-full h-full object-cover"
                    />
                </div>

                <!-- Punto central animado literal -->
                <div class="absolute inset-0 flex items-center justify-center">
                    <div class="w-4 h-4 bg-primary animate-ping rounded-full">
                    </div>
                </div>
            </div>
        </div>
    </Container>
</section>