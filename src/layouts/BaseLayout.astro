---
import { Font } from "astro:assets";
import "@/styles/global.css";
import SEO from "@/components/common/Seo.astro";
import Navbar from "@/components/common/Navbar.astro";
import Footer from "@/components/common/Footer.astro";

interface Props {
	title?: string;
	description?: string;
	image?: string;
	canonicalURL?: string;
}

const { title, description, image, canonicalURL } = Astro.props;
---

<!doctype html>
<html lang="es">
	<!-- Head -->
	<head>
		<!-- Global Metadata -->
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width,initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- Fonts -->
		<Font cssVariable="--font-headline" preload />
		<Font cssVariable="--font-body" preload />
		<Font cssVariable="--font-serif" />
		<Font cssVariable="--font-sans" />
		<Font cssVariable="--font-mono" />
		<Font cssVariable="--font-icons" />

		<!-- SEO -->
		<SEO {title} {description} {image} {canonicalURL} />
	</head>


	<!-- Body -->
	<body class="flex flex-col min-h-screen noise-texture">
		<div class="grain-overlay" />
		<Navbar />

		<main class="grow pt-24">
			<slot />
		</main>

		<Footer />
	</body>
</html>

<style is:global>
	/* Ensure smooth scroll for anchor links (on accessibility is disabled) */
	@media (prefers-reduced-motion: no-preference) {
		html {
			scroll-behavior: smooth;
		}
	}
</style>
